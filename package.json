{
  "name": "finnish-national-parks-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "db:migrate": "tsx src/cli/migrate.ts",
    "import:parks": "tsx src/cli/import-parks.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "verify": "npm run typecheck && npm run lint && npm run test:coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@hono/zod-openapi": "^1.1.4",
    "@libsql/client": "^0.15.15",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.10.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
