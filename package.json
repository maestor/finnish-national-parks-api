{
  "name": "finnish-national-parks-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/local-server.ts",
    "start": "tsx src/local-server.ts",
    "db:backup": "tsx src/cli/backup-turso.ts",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:migrate:pending": "tsx src/cli/check-pending-migrations.ts",
    "import:parks": "tsx src/cli/import-parks.ts",
    "import:special-parks": "tsx src/cli/import-special-parks.ts",
    "park:move-visits": "tsx src/cli/move-park-visits.ts",
    "park:logo": "tsx src/cli/upload-park-logo.ts",
    "park:logos": "tsx src/cli/upload-all-park-logos.ts",
    "park:map": "tsx src/cli/upload-park-map.ts",
    "park:maps": "tsx src/cli/upload-all-park-maps.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "node scripts/run-biome-check.mjs .",
    "lint:fix": "node scripts/run-biome-check.mjs --write .",
    "verify": "npm run typecheck && npm run lint:fix && npm run test:coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@hono/node-server": "^2.0.11",
    "@hono/zod-openapi": "^1.5.1",
    "@libsql/client": "^0.17.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "jose": "^6.2.4",
    "pino": "^10.3.1",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
