# Copy this file to .env and adjust values as needed.
# Only required for local development if you want to override defaults.

# API key for protecting non-public endpoints.
# Leave unset to disable authentication locally if you want.
# Localhost requests bypass auth even when this is set.
# Vercel deployments should always set this.
API_KEY=your-local-dev-key

# Database URL. Local SQLite file is the default.
# Vercel deployments must use Turso/libSQL, for example: libsql://your-db.turso.io
DATABASE_URL=file:./data/local.db

# Turso authentication token. Only needed for remote Turso databases.
DATABASE_AUTH_TOKEN=

# Server port. Defaults to 3004 if unset.
PORT=3004

# Google OAuth credentials. Create these at https://console.cloud.google.com/apis/credentials
# Redirect URI must include:
# - local: http://localhost:3004/auth/google/callback
# - Vercel direct-to-API: https://your-api-domain.vercel.app/auth/google/callback
# - Vercel via frontend proxy/rewrite: https://your-frontend-domain.vercel.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# JWT secret for session cookies. Must be at least 32 characters.
# Frontend middleware uses the same secret to verify tokens locally.
AUTH_JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars

# Session cookie name. Defaults to __session.
AUTH_COOKIE_NAME=__session

# Frontend URL for post-login redirects and CORS. Defaults to http://localhost:4300.
# If Google OAuth is enabled on Vercel, this must be your deployed frontend URL.
FRONTEND_URL=http://localhost:4300

# Optional public callback URL for Google OAuth when /auth/* is exposed through
# a frontend proxy or rewrite instead of the API's own domain.
# Leave unset locally and for direct-to-API production callbacks.
# If you set this in Vercel, it must be the same URI you register in Google Cloud.
# Example: https://your-frontend-domain.vercel.app/auth/google/callback
# GOOGLE_REDIRECT_URI=

# Cloudflare R2 (S3-compatible) storage for visit images.
# The bucket can be private — the API generates presigned URLs for access.
# Leave all unset to disable image upload routes locally.
# MEMORY_STORAGE=true uses an in-memory fake instead of R2 (useful for tests only).
# Do not use MEMORY_STORAGE=true on Vercel.
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
MEMORY_STORAGE=false
