# Copy this file to .env and adjust values as needed.
# Only required for local development if you want to override defaults.

# API key for protecting non-public endpoints.
# Leave unset to disable authentication (useful for local development).
# Localhost requests bypass auth even when this is set.
API_KEY=your-local-dev-key

# Database URL. Local SQLite file is the default.
# For Turso production, use: libsql://your-db.turso.io
DATABASE_URL=file:./data/local.db

# Turso authentication token. Only needed for remote Turso databases.
DATABASE_AUTH_TOKEN=

# LIPAS protected areas API URL.
# The default fetches national parks, wilderness areas, hiking areas, and nature reserves.
LIPAS_PROTECTED_AREAS_URL=https://api.lipas.fi/v2/sports-sites?type-codes=109,110,111,112&page-size=100&page=1

# Server port. Defaults to 3004 if unset.
PORT=3004

# Google OAuth credentials. Create these at https://console.cloud.google.com/apis/credentials
# Redirect URI must include: http://localhost:3004/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret for session cookies. Must be at least 32 characters.
# Frontend middleware uses the same secret to verify tokens locally.
AUTH_JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars

# Session cookie name. Defaults to __session.
AUTH_COOKIE_NAME=__session

# Frontend URL for OAuth redirects and CORS. Defaults to http://localhost:4300.
FRONTEND_URL=http://localhost:4300

# Cloudflare R2 (S3-compatible) storage for visit images.
# Leave all unset to disable image upload routes locally.
# MEMORY_STORAGE=true uses an in-memory fake instead of R2 (useful for tests).
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
MEMORY_STORAGE=false
